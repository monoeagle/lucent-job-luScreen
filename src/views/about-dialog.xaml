<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ueber LucentScreen"
        Width="420" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Image x:Name="ImgIcon" Width="48" Height="48" Margin="0,0,14,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TxtName" Text="LucentScreen" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtVersion" Foreground="#666"/>
            </StackPanel>
        </StackPanel>

        <Separator Grid.Row="1" Margin="0,4,0,12"/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Windows-Screenshot-Tool mit Tray, Hotkeys, Editor und Verlauf."
                       TextWrapping="Wrap" Margin="0,0,0,10"/>
            <TextBlock Foreground="#555" FontSize="11.5">
                <Run Text="Stack: PowerShell 5.1 + WPF + GDI+"/>
                <LineBreak/>
                <Run Text="Verteilung: signiertes Bundle, vom Softwareverteilteam als MSI paketiert"/>
                <LineBreak/>
                <Run Text="Lizenz: intern"/>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk" Content="Schliessen" Width="100" Height="28" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
