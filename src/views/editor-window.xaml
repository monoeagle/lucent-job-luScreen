<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LucentScreen — Editor"
        Width="1240" Height="820"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="White" BorderBrush="#D7DCE3"
                                BorderThickness="1" CornerRadius="4" Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#9DB8E0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Swatch" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="#D7DCE3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top-Toolbar (Save / Zoom / Close) -->
        <Border Grid.Row="0" Background="#F5F6F8" BorderBrush="#E2E5EB" BorderThickness="0,0,0,1" Padding="10,8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnSave"      Content="Speichern (Strg+S)" MinWidth="160" Margin="0,0,12,0"/>
                    <Separator Margin="0,0,12,0"/>
                    <Button x:Name="BtnUndo"      Content="Undo (Strg+Z)"   MinWidth="120" Margin="0,0,4,0"/>
                    <Button x:Name="BtnRedo"      Content="Redo (Strg+Y)"   MinWidth="120" Margin="0,0,12,0"/>
                    <Button x:Name="BtnCropApply" Content="Zuschnitt anwenden (Enter)" MinWidth="200" Margin="0,0,4,0" Visibility="Collapsed"/>
                    <Button x:Name="BtnCropCancel" Content="Zuschnitt abbrechen"        MinWidth="160" Margin="0,0,12,0" Visibility="Collapsed"/>
                    <Separator Margin="0,0,12,0"/>
                    <Button x:Name="BtnFit"       Content="Fit-to-Window"   MinWidth="120" Margin="0,0,6,0"/>
                    <Button x:Name="BtnZoom100"   Content="100%"             MinWidth="70"  Margin="0,0,6,0"/>
                    <Button x:Name="BtnZoomOut"   Content="−"                MinWidth="34"  Margin="0,0,2,0"/>
                    <Button x:Name="BtnZoomIn"    Content="+"                MinWidth="34"  Margin="0,0,12,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="BtnClose"     Content="Schliessen (Esc)" MinWidth="140"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Side-Panel + Stage -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Side-Panel: Tools + Color + Stroke -->
            <Border Grid.Column="0" Background="#F8F9FB" BorderBrush="#E2E5EB" BorderThickness="0,0,1,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Werkzeug" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <RadioButton x:Name="ToolSelect"    Style="{StaticResource ToolBtn}" GroupName="Tool" IsChecked="True" Content="Auswahl (V)"/>
                    <RadioButton x:Name="ToolRectangle" Style="{StaticResource ToolBtn}" GroupName="Tool" Content="Rahmen (R)"/>
                    <RadioButton x:Name="ToolLine"      Style="{StaticResource ToolBtn}" GroupName="Tool" Content="Linie (L)"/>
                    <RadioButton x:Name="ToolArrow"     Style="{StaticResource ToolBtn}" GroupName="Tool" Content="Pfeil (A)"/>
                    <RadioButton x:Name="ToolBar"       Style="{StaticResource ToolBtn}" GroupName="Tool" Content="Balken (B)"/>
                    <RadioButton x:Name="ToolMarker"    Style="{StaticResource ToolBtn}" GroupName="Tool" Content="Marker (M)"/>
                    <RadioButton x:Name="ToolCrop"      Style="{StaticResource ToolBtn}" GroupName="Tool" Content="Zuschneiden (C)"/>

                    <TextBlock Text="Farbe" FontWeight="SemiBold" Margin="0,12,0,6"/>
                    <WrapPanel x:Name="ColorPalette">
                        <Button x:Name="ClrRed"    Style="{StaticResource Swatch}" Background="#E11D48" ToolTip="Rot"/>
                        <Button x:Name="ClrOrange" Style="{StaticResource Swatch}" Background="#F97316" ToolTip="Orange"/>
                        <Button x:Name="ClrYellow" Style="{StaticResource Swatch}" Background="#FACC15" ToolTip="Gelb"/>
                        <Button x:Name="ClrGreen"  Style="{StaticResource Swatch}" Background="#16A34A" ToolTip="Gruen"/>
                        <Button x:Name="ClrBlue"   Style="{StaticResource Swatch}" Background="#2563EB" ToolTip="Blau"/>
                        <Button x:Name="ClrMagenta" Style="{StaticResource Swatch}" Background="#DB2777" ToolTip="Magenta"/>
                        <Button x:Name="ClrBlack"  Style="{StaticResource Swatch}" Background="#111827" ToolTip="Schwarz"/>
                        <Button x:Name="ClrWhite"  Style="{StaticResource Swatch}" Background="#FFFFFF" ToolTip="Weiss"/>
                    </WrapPanel>
                    <Border x:Name="CurrentColor" Height="6" Margin="2,6,2,0" Background="#E11D48" CornerRadius="3"/>

                    <TextBlock Text="Strichstaerke" FontWeight="SemiBold" Margin="0,16,0,4"/>
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="TxtStroke" DockPanel.Dock="Right" Text="3 px" Foreground="#666" MinWidth="40" TextAlignment="Right"/>
                        <Slider x:Name="SldStroke" Minimum="1" Maximum="20" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,6,0"/>
                    </DockPanel>

                    <TextBlock Text="Tipp: Strg+Z/Y, V/R/L/A/B/M/C, Enter=Crop anwenden" FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>

            <!-- Stage -->
            <ScrollViewer Grid.Column="1" x:Name="Scroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#1A1D26">
                <Grid x:Name="StageRoot"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="StageScale" ScaleX="1" ScaleY="1"/>
                    </Grid.LayoutTransform>
                    <Image x:Name="ImgBitmap" Stretch="None"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Canvas x:Name="ShapeLayer" Background="Transparent"
                            IsHitTestVisible="True"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Statusbar -->
        <Border Grid.Row="2" Background="#F5F6F8" BorderBrush="#E2E5EB" BorderThickness="0,1,0,0" Padding="10,4">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="TxtStatus" DockPanel.Dock="Left" Foreground="#444"/>
                <TextBlock x:Name="TxtZoom"   DockPanel.Dock="Right" Foreground="#666" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
