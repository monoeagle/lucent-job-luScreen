<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LucentScreen — Verlauf"
        Width="1110" Height="1080"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <!-- Icon-Toolbar-Style: quadratisch, zentriert, Segoe-MDL2-Glyph als Content -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Schloss-Button im ItemTemplate: Glyph wechselt per DataTrigger
             zwischen offen (E785) und zu (E72E). -->
        <!-- Offen (entsperrt) = Gruen, zu (gesperrt) = Rot. Hintergrund mit
             leichter Transparenz (Alpha CC = 80%), damit die Farbe deutlich
             sichtbar bleibt, ohne den Bildhintergrund komplett zu verdecken. -->
        <Style x:Key="LockButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#CCDCFCE7"/>
            <Setter Property="BorderBrush" Value="#16A34A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Content" Value="&#xE785;"/>
            <Setter Property="ToolTip" Value="Sperren -- vor versehentlichem Löschen schützen"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="Content" Value="&#xE72E;"/>
                    <Setter Property="Foreground" Value="#B91C1C"/>
                    <Setter Property="Background" Value="#CCFEE2E2"/>
                    <Setter Property="BorderBrush" Value="#DC2626"/>
                    <Setter Property="ToolTip" Value="Entsperren -- Löschen wieder erlauben"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="#E2E5EB"
                                Background="White"
                                Padding="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#9DB8E0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="Bd" Property="Background" Value="#EFF4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#F5F6F8" BorderBrush="#E2E5EB" BorderThickness="0,0,0,1" Padding="10,8">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnView"      Style="{StaticResource IconButton}" Content="&#xE890;"
                            ToolTip="Anzeigen -- Bild im Standard-Bildbetrachter öffnen"/>
                    <Button x:Name="BtnEdit"      Style="{StaticResource IconButton}" Content="&#xE70F;"
                            ToolTip="Bearbeiten -- Bild im LucentScreen-Editor öffnen (Doppelklick / Enter)"/>
                    <Button x:Name="BtnRename"    Style="{StaticResource IconButton}" Content="&#xE8AC;"
                            ToolTip="Umbenennen -- markierte Datei neu benennen (F2)"/>
                    <Button x:Name="BtnReveal"    Style="{StaticResource IconButton}" Content="&#xE838;"
                            ToolTip="Speicherort -- Ordner im Explorer oeffnen, Datei markiert"/>
                    <Button x:Name="BtnCopy"      Style="{StaticResource IconButton}" Content="&#xE8C8;"
                            ToolTip="Zwischenablage -- markiertes Bild als Image kopieren (Strg+C)"/>
                    <Button x:Name="BtnCopyMulti" Style="{StaticResource IconButton}" Content="&#xE16F;"
                            ToolTip="Zwischenablage (Liste) -- markierte Dateien als Datei-Liste, Einfuegen in Word/Outlook fuegt alle Bilder ein"/>
                    <Button x:Name="BtnRefresh"   Style="{StaticResource IconButton}" Content="&#xE72C;"
                            ToolTip="Aktualisieren -- Verlauf neu einlesen (F5)"/>
                    <Border Width="1" Margin="6,2,8,2" Background="#D5D9E0"/>
                    <Button x:Name="BtnDruck"     Style="{StaticResource IconButton}" Content="&#xE77F;"
                            IsEnabled="False"
                            ToolTip="Druck -- Bild aus der Zwischenablage als PNG speichern (Strg+V; aktiv sobald Druck/Snipping/Copy ein Bild abgelegt hat)"/>
                    <Border Width="1" Margin="6,2,8,2" Background="#D5D9E0"/>
                    <Button x:Name="BtnDelete"    Style="{StaticResource IconButton}" Content="&#xE74D;"
                            ToolTip="Löschen -- markierte Bilder in den Papierkorb verschieben (Entf); gesperrte Bilder werden uebersprungen"/>
                </StackPanel>
                <TextBlock x:Name="TxtFolder" DockPanel.Dock="Right" Foreground="#666"
                           VerticalAlignment="Center" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Liste -->
        <ListBox x:Name="LstItems"
                 Grid.Row="1"
                 BorderThickness="0"
                 Background="#FAFBFC"
                 SelectionMode="Extended"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 KeyboardNavigation.DirectionalNavigation="Contained">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ContextMenu>
                <ContextMenu x:Name="ItemMenu">
                    <MenuItem x:Name="MiEdit"   Header="Editieren"/>
                    <MenuItem x:Name="MiOpen"   Header="Öffnen (Default-App)"/>
                    <MenuItem x:Name="MiReveal" Header="Im Ordner zeigen"/>
                    <MenuItem x:Name="MiCopy"   Header="In Zwischenablage kopieren"/>
                    <Separator/>
                    <MenuItem x:Name="MiRename" Header="Umbenennen…"/>
                    <MenuItem x:Name="MiDelete" Header="In Papierkorb verschieben"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="200">
                        <Grid Width="200" Height="130">
                            <Border Background="#EEF1F5"
                                    CornerRadius="4"
                                    ClipToBounds="True">
                                <Image Source="{Binding Thumbnail}"
                                       Stretch="Uniform"
                                       StretchDirection="DownOnly"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <!-- Schloss-Overlay rechts oben. Tag = Entry,
                                 ausgelesen vom Click-Handler im Code. -->
                            <Button x:Name="BtnLock"
                                    Style="{StaticResource LockButton}"
                                    Tag="{Binding}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,4,4,0"/>
                        </Grid>
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="12" Margin="2,6,2,0"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FullName}"/>
                        <TextBlock FontSize="11" Foreground="#888" Margin="2,2,2,0">
                            <Run Text="{Binding TimeDisplay}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding SizeDisplay}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Statusbar -->
        <Border Grid.Row="2" Background="#F5F6F8" BorderBrush="#E2E5EB" BorderThickness="0,1,0,0" Padding="10,4">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="TxtStatus" DockPanel.Dock="Left" Foreground="#444"/>
                <TextBlock x:Name="TxtSelection" DockPanel.Dock="Right" Foreground="#666" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
