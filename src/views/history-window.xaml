<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LucentScreen — Verlauf"
        Width="1110" Height="1080"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="#E2E5EB"
                                Background="White"
                                Padding="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#9DB8E0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="Bd" Property="Background" Value="#EFF4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#F5F6F8" BorderBrush="#E2E5EB" BorderThickness="0,0,0,1" Padding="10,8">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnOpen"    Content="Oeffnen"        MinWidth="90" Margin="0,0,6,0"/>
                    <Button x:Name="BtnReveal"  Content="Im Ordner..."   MinWidth="100" Margin="0,0,6,0"/>
                    <Button x:Name="BtnCopy"    Content="In Clipboard"   MinWidth="110" Margin="0,0,6,0"/>
                    <Button x:Name="BtnDelete"  Content="Loeschen"       MinWidth="90" Margin="0,0,12,0"/>
                    <Button x:Name="BtnRefresh" Content="Aktualisieren"  MinWidth="100"/>
                </StackPanel>
                <TextBlock x:Name="TxtFolder" DockPanel.Dock="Right" Foreground="#666"
                           VerticalAlignment="Center" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Liste -->
        <ListBox x:Name="LstItems"
                 Grid.Row="1"
                 BorderThickness="0"
                 Background="#FAFBFC"
                 SelectionMode="Extended"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 KeyboardNavigation.DirectionalNavigation="Contained">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ContextMenu>
                <ContextMenu x:Name="ItemMenu">
                    <MenuItem x:Name="MiEdit"   Header="Editieren"/>
                    <MenuItem x:Name="MiOpen"   Header="Oeffnen (Default-App)"/>
                    <MenuItem x:Name="MiReveal" Header="Im Ordner zeigen"/>
                    <MenuItem x:Name="MiCopy"   Header="In Zwischenablage kopieren"/>
                    <Separator/>
                    <MenuItem x:Name="MiDelete" Header="In Papierkorb verschieben"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="200">
                        <Border Width="200" Height="130"
                                Background="#EEF1F5"
                                CornerRadius="4"
                                ClipToBounds="True">
                            <Image Source="{Binding Thumbnail}"
                                   Stretch="Uniform"
                                   StretchDirection="DownOnly"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="12" Margin="2,6,2,0"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FullName}"/>
                        <TextBlock FontSize="11" Foreground="#888" Margin="2,2,2,0">
                            <Run Text="{Binding TimeDisplay}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding SizeDisplay}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Statusbar -->
        <Border Grid.Row="2" Background="#F5F6F8" BorderBrush="#E2E5EB" BorderThickness="0,1,0,0" Padding="10,4">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="TxtStatus" DockPanel.Dock="Left" Foreground="#444"/>
                <TextBlock x:Name="TxtSelection" DockPanel.Dock="Right" Foreground="#666" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
