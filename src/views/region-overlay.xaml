<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LucentScreen Region"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#33000000"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Cursor="Cross">
    <Grid x:Name="Root">
        <Canvas x:Name="Cv">
            <Rectangle x:Name="Sel"
                       Stroke="#FF00B7EB"
                       StrokeThickness="2"
                       Fill="#3300B7EB"
                       Visibility="Collapsed"/>
            <TextBlock x:Name="HintText"
                       Canvas.Left="20" Canvas.Top="20"
                       Foreground="White"
                       Background="#AA000000"
                       Padding="10,6"
                       FontFamily="Segoe UI" FontSize="14"
                       Text="Bereich ziehen mit Maus  |  ESC = Abbrechen"/>
            <TextBlock x:Name="SizeText"
                       Foreground="White"
                       Background="#AA000000"
                       Padding="6,2"
                       FontFamily="Segoe UI" FontSize="12"
                       Visibility="Collapsed"/>
        </Canvas>
    </Grid>
</Window>
